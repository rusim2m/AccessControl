################################################################################
# .gitignore for AccessControlPlatform (frontend + backend + tools)
# Patterns without a leading "/" match at any depth (frontend/, backend/, tools/).
################################################################################

# Dependencies (regenerated by `npm install`)
node_modules/

# Build output
dist/
build/
bin/
obj/

# Visual Studio / IDE
.vs/
*.user
.idea/

# Local tool settings
settings.local.json

# Local config / secrets
.env
.env.local

# Logs & OS junk
*.log
.DS_Store
Thumbs.db
